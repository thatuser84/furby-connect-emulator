#!/bin/sh
# Launch the Furby Connect emulator GUI.
# macOS note: Apple's system Tk (8.5) is broken on some builds and cannot open a window;
# this uses a Python with a working Tk 8.6 if one is available, else falls back to python3.
DIR="$(cd "$(dirname "$0")" && pwd)"
for PY in "$HOME/miniconda3/bin/python3" "$HOME/anaconda3/bin/python3" \
          /Library/Frameworks/Python.framework/Versions/*/bin/python3 \
          /opt/homebrew/bin/python3 /usr/local/bin/python3 python3; do
    [ -x "$PY" ] || command -v "$PY" >/dev/null 2>&1 || continue
    TKV="$("$PY" -c 'import tkinter;print(tkinter.TkVersion)' 2>/dev/null)"
    [ "$TKV" = "8.6" ] || [ "$TKV" = "9.0" ] && { exec "$PY" "$DIR/run.py" --gui "$@"; }
done
echo "No Python with a working Tk 8.6 found. Install one, e.g. Miniconda:" >&2
echo "  curl -fsSL -o mc.sh https://repo.anaconda.com/miniconda/Miniconda3-latest-MacOSX-x86_64.sh && bash mc.sh -b" >&2
exit 1
